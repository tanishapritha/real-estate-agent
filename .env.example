# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/real_estate_agent

# Cache & Message Broker Configuration
REDIS_URL=redis://localhost:6379/0

# LLM Provider API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# LangSmith / LangChain Tracing Configuration
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=real-estate-sales-os

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
API_KEY_SECRET=dev-secret-key-12345
PORT=8000
HOST=127.0.0.1
